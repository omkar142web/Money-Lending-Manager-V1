<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard</title>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: Arial, sans-serif;
      background: #0f172a;
      color: white;
      min-height: 100vh;
      padding: 30px;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    .container {
      max-width: 1200px;
      margin: auto;
    }

    .topbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 30px;
      flex-wrap: wrap;
      gap: 15px;
    }

    .welcome h1 {
      font-size: 2rem;
      margin-bottom: 8px;
    }

    .welcome p {
      color: #94a3b8;
    }

    .logout-btn {
      background: #ef4444;
      padding: 10px 18px;
      border-radius: 10px;
      transition: 0.3s;
    }

    .logout-btn:hover {
      background: #dc2626;
    }

    .stats {
      display: flex;
      gap: 15px;
      margin-bottom: 30px;
      flex-wrap: wrap;
    }

    .stat-card {
      background: #1e293b;
      padding: 20px;
      border-radius: 18px;
      flex: 1;
      min-width: 180px;
    }

    .stat-card h2 {
      font-size: 2rem;
      margin-top: 10px;
    }

    .section-title {
      margin-bottom: 20px;
      font-size: 1.5rem;
    }

    .cards {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 20px;
    }

    .card {
      background: #1e293b;
      border-radius: 20px;
      padding: 20px;
      position: relative;
      overflow: hidden;
      transition: 0.3s;
      border: 1px solid transparent;
    }

    .card:hover {
      transform: translateY(-5px);
      border-color: #3b82f6;
    }

    .card-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 18px;
    }

    .badge {
      background: #2563eb;
      color: white;
      font-size: 12px;
      padding: 5px 10px;
      border-radius: 999px;
    }

    .property {
      margin-bottom: 14px;
    }

    .property-label {
      font-size: 12px;
      text-transform: uppercase;
      color: #94a3b8;
      margin-bottom: 4px;
      letter-spacing: 1px;
    }

    .property-value {
      word-break: break-word;
      line-height: 1.5;
    }

    .property-value a {
      color: #60a5fa;
    }

    .actions {
      display: flex;
      gap: 10px;
      margin-top: 20px;
    }

    .btn {
      flex: 1;
      text-align: center;
      padding: 10px;
      border-radius: 10px;
      transition: 0.3s;
      cursor: pointer;
    }

    .edit-btn {
      background: #334155;
    }

    .edit-btn:hover {
      background: #475569;
    }

    .delete-btn {
      background: #7f1d1d;
    }

    .delete-btn:hover {
      background: #991b1b;
    }

    .empty {
      background: #1e293b;
      padding: 30px;
      border-radius: 18px;
      text-align: center;
      color: #94a3b8;
    }

    .search-box {
      margin-bottom: 25px;
    }

    .search-box input {
      width: 100%;
      padding: 14px 18px;
      border-radius: 14px;
      border: none;
      outline: none;
      background: #1e293b;
      color: white;
      font-size: 15px;
    }

    @media (max-width: 600px) {
      body {
        padding: 18px;
      }

      .welcome h1 {
        font-size: 1.5rem;
      }

      .cards {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>

<body>
  <div class="container">

    <!-- TOPBAR -->
    <div class="topbar">
      <div class="welcome">
        <h1>
          Welcome back,
          <%= user?.name || "User" %> 👋
        </h1>

        <p>
          Email:
          <%= user?.email %>
        </p>
      </div>

      <a href="/logout" class="logout-btn">
        Logout
      </a>
    </div>

    <!-- STATS -->
    <div class="stats">
      <div class="stat-card">
        <p>Total Records</p>
        <h2><%= data.length %></h2>
      </div>

      <div class="stat-card">
        <p>Latest Added</p>
        <h2>
          <%= data[data.length - 1]?.name || "—" %>
        </h2>
      </div>
    </div>

    <!-- SEARCH -->
    <div class="search-box">
      <input type="text" id="searchInput" placeholder="Search anything..." />
    </div>

    <h2 class="section-title">Your Data</h2>

    <% if(data.length === 0){ %>

    <div class="empty">
      No data found.
    </div>

    <% } else { %>

    <div class="cards" id="cardsContainer">

      <% data.forEach((item, index) => { %>

      <div class="card" data-search="<%= JSON.stringify(item).toLowerCase() %>">

        <div class="card-header">
          <h3>
            <%= item.name || "Untitled" %>
          </h3>

          <span class="badge">
            #<%= index + 1 %>
          </span>
        </div>

        <!-- DYNAMIC PROPERTIES -->
        <% Object.keys(item).forEach((key) => { %>

        <% if(key !== "__v"){ %>

        <div class="property">

          <div class="property-label">
            <%= key %>
          </div>

          <div class="property-value">

            <% 
                  const value = item[key];
                  const isUrl =
                    typeof value === "string" &&
                    (value.startsWith("http://") ||
                    value.startsWith("https://"));
                %>

            <% if(isUrl){ %>

            <a href="<%= value %>" target="_blank">
              <%= value %>
            </a>

            <% } else { %>

            <%= typeof value === "object"
                    ? JSON.stringify(value, null, 2)
                    : value %>

            <% } %>

          </div>
        </div>

        <% } %>

        <% }) %>

        <!-- ACTIONS -->
        <div class="actions">

          <a href="/edit/<%= item._id %>" class="btn edit-btn">
            Edit
          </a>

          <a href="/delete/<%= item._id %>" class="btn delete-btn" onclick="return confirm('Delete this item?')">
            Delete
          </a>

        </div>

      </div>

      <% }) %>

    </div>

    <% } %>

  </div>

  <script>
    const searchInput = document.getElementById("searchInput");
    const cards = document.querySelectorAll(".card");

    searchInput.addEventListener("input", (e) => {
      const value = e.target.value.toLowerCase();

      cards.forEach((card) => {
        const searchable = card.dataset.search;

        if (searchable.includes(value)) {
          card.style.display = "block";
        } else {
          card.style.display = "none";
        }
      });
    });
  </script>
</body>

</html>